---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import WaveDivider from '../components/ui/WaveDivider.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import MarqueeText from '../components/ui/MarqueeText.astro';
import FinalCTA from '../components/ui/FinalCTA.astro';
import { siteInfo } from '../data/navigation';
import { getLocalBusinessSchema, getBreadcrumbSchema } from '../data/seo';

const structuredData = [
  getLocalBusinessSchema(),
  getBreadcrumbSchema([
    { name: 'Home', url: 'https://nutricionistajackeline.com.br/' },
    { name: 'Sobre', url: 'https://nutricionistajackeline.com.br/sobre' },
  ]),
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Jackeline Queiroz',
    jobTitle: 'Nutricionista Funcional e Esportiva',
    description: 'Nutricionista clínica e esportiva funcional com mais de 15 anos de experiência em São Paulo.',
    knowsAbout: ['Nutrição Funcional', 'Nutrição Esportiva', 'Emagrecimento', 'Composição Corporal', 'Saúde da Mulher'],
    alumniOf: [
      { '@type': 'CollegeOrUniversity', name: 'Centro Universitário do Triângulo Mineiro' },
      { '@type': 'CollegeOrUniversity', name: 'VP Consultoria Nutricional' },
      { '@type': 'CollegeOrUniversity', name: 'Instituto Ganep' },
    ],
    memberOf: { '@type': 'Organization', name: 'IBNF - Instituto Brasileiro de Nutrição Funcional' },
    url: 'https://nutricionistajackeline.com.br/sobre',
  },
];
---

<BaseLayout
  title="Sobre Dra Jackeline Queiroz | Nutricionista com +15 Anos de Experiência"
  description="Conheça a Dra Jackeline Queiroz: nutricionista funcional e esportiva em São Paulo, com 3 pós-graduações e mais de 15 anos de experiência em consultório."
  structuredData={structuredData}
>

  <!-- ========== HERO (fullwidth bg + overlay + wave) ========== -->
  <section class="sobre-hero" aria-labelledby="sobre-heading">
    <div class="sobre-hero-bg" id="hero-parallax-bg" aria-hidden="true">
      <img
        src="/images/about/nutricionista-jackeline2.png"
        alt=""
        class="sobre-hero-bg-img"
        width="1440"
        height="900"
        fetchpriority="high"
      />
      <div class="sobre-hero-overlay"></div>
    </div>
    <div class="container sobre-hero-content">
      <div class="reveal fade-up">
        <span class="overline">Conheça a Dra Jackeline</span>
        <h1 id="sobre-heading">Uma rotina de saúde que funciona <em>com a sua vida</em>, não contra ela</h1>
        <p>
          Nutricionista clínica e esportiva funcional com especialização em comportamento alimentar
          e mais de 15 anos de experiência em consultório.
        </p>
      </div>
    </div>
    <div class="sobre-hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 150" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,80 C240,140 480,20 720,80 C960,140 1200,40 1440,80 L1440,150 L0,150 Z" fill="var(--color-cream)" />
      </svg>
    </div>
  </section>

  <!-- ========== BIO (image left, text right) ========== -->
  <section class="bio" aria-labelledby="bio-heading">
    <div class="container bio-grid">
      <div class="bio-image reveal scale-in">
        <div class="bio-image-wrapper">
          <img
            src="/images/about/jackeline-about.png"
            alt="Dra Jackeline Queiroz, nutricionista funcional e esportiva"
            width="480"
            height="580"
            loading="lazy"
          />
        </div>
      </div>
      <div class="bio-text reveal fade-up">
        <span class="overline">Sobre a Dra Jackeline</span>
        <h2 id="bio-heading">Mineira, nutricionista e apaixonada por <em>transformar vidas</em></h2>
        <p>
          Formada em Nutrição pelo Centro Universitário do Triângulo Mineiro em 2008, construí
          uma trajetória sólida unindo ciência, prática clínica e comportamento alimentar, com
          cursos de extensão em nutrição esportiva, bioquímica, exames laboratoriais e nutrição comportamental.
        </p>
        <p>
          Hoje, com mais de 15 anos de experiência em consultório, acompanho praticantes de crossfit,
          corrida, triathlon e lutas, com um método que torna a jornada mais leve, possível e
          sustentável — sem dietas extremas ou soluções temporárias.
        </p>
        <blockquote>
          "Amo acompanhar de perto a transformação dos meus pacientes — resultado de verdade acontece
          quando existe orientação, constância e apoio ao longo do caminho."
        </blockquote>
      </div>
    </div>
  </section>

  <!-- ========== STATS BANNER ========== -->
  <section class="stats-banner" aria-label="Números da trajetória">
    <div class="container">
      <div class="stats-grid stagger">
        <div class="stat-item reveal fade-up">
          <span class="stat-number">+15</span>
          <span class="stat-label">anos de experiência em consultório</span>
        </div>
        <div class="stat-item reveal fade-up">
          <span class="stat-number">3</span>
          <span class="stat-label">pós-graduações concluídas</span>
        </div>
        <div class="stat-item reveal fade-up">
          <span class="stat-number">3</span>
          <span class="stat-label">consultórios em São Paulo</span>
        </div>
        <div class="stat-item reveal fade-up">
          <span class="stat-number">+2000</span>
          <span class="stat-label">pacientes acompanhados</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== EXPERIENCE (timeline + sticky image) ========== -->
  <section class="experience" aria-labelledby="experience-heading">
    <div class="container">
      <SectionHeading overline="TRAJETÓRIA" align="center">
        Experiência <em>profissional</em>
      </SectionHeading>

      <div class="experience-layout">
        <div class="experience-timeline stagger">
          <div class="timeline-item reveal fade-up">
            <div class="timeline-marker"></div>
            <div class="timeline-content">
              <h3>2008–2010 · Hospital Santa Catarina — EMTN</h3>
              <p>
                Equipe Multidisciplinar de Terapia Nutricional em São Paulo, atuando com nutrição
                enteral e parenteral. Base clínica sólida e olhar responsável.
              </p>
            </div>
          </div>
          <div class="timeline-item reveal fade-up">
            <div class="timeline-marker"></div>
            <div class="timeline-content">
              <h3>2010+ · Consultório Clínico</h3>
              <p>
                Atendimentos focados em emagrecimento, saúde e bem-estar. Acompanhamento de
                intolerâncias, doenças autoimunes, gestação e inflamações intestinais.
              </p>
            </div>
          </div>
          <div class="timeline-item reveal fade-up">
            <div class="timeline-marker"></div>
            <div class="timeline-content">
              <h3>Nutrição Esportiva</h3>
              <p>
                Performance e composição corporal para praticantes de atividade física e atletas
                amadores, respeitando rotina de treinos e objetivos individuais.
              </p>
            </div>
          </div>
          <div class="timeline-item reveal fade-up">
            <div class="timeline-marker"></div>
            <div class="timeline-content">
              <h3>Nutrição Comportamental</h3>
              <p>
                Cuidado que vai além do alimento: comportamento alimentar, hábitos, rotina e a
                relação com a comida para mudanças reais e sustentáveis.
              </p>
            </div>
          </div>
        </div>
        <div class="experience-image">
          <img
            src="/images/about/experiencia.png"
            alt="Dra Jackeline em atendimento"
            width="480"
            height="580"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WAVE: cream → dark ========== -->
  <WaveDivider topColor="var(--color-cream)" bottomColor="var(--color-blue-800)" variant={1} />

  <!-- ========== CREDENTIALS ========== -->
  <section class="credentials text-on-dark" aria-labelledby="credentials-heading">
    <div class="container">
      <SectionHeading overline="FORMAÇÃO" align="center" onDark>
        Currículo e <em>credenciais</em>
      </SectionHeading>

      <div class="credentials-grid stagger">
        <div class="credential-card reveal fade-up">
          <div class="credential-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-400)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 1.1 2.7 3 6 3s6-1.9 6-3v-5"/></svg>
          </div>
          <h3>Nutrição Clínica Funcional</h3>
          <p>Pós-graduação pela VP Consultoria Nutricional, São Paulo</p>
        </div>
        <div class="credential-card reveal fade-up">
          <div class="credential-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-400)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="13" y2="11"/></svg>
          </div>
          <h3>Nutrição Esportiva Funcional</h3>
          <p>Pós-graduação pela VP Consultoria Nutricional, São Paulo</p>
        </div>
        <div class="credential-card reveal fade-up">
          <div class="credential-icon" aria-hidden="true">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-400)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M9 8h1M9 12h1M9 16h1M14 8h1M14 12h1M14 16h1"/><path d="M5 21V5a2 2 0 012-2h10a2 2 0 012 2v16"/></svg>
          </div>
          <h3>Nutrição Clínica e Terapia Nutricional</h3>
          <p>Pós-graduação pelo Instituto Ganep, com atendimento prático no Hospital Beneficência Portuguesa</p>
        </div>
      </div>

      <div class="credentials-badges reveal fade-up">
        <h3>Formação complementar</h3>
        <div class="badges-wrap">
          <span class="badge">Universidade do Triângulo Mineiro</span>
          <span class="badge">Nutrição Funcional e Ortomolecular</span>
          <span class="badge">Saúde da Mulher</span>
          <span class="badge">Suplementos Esportivos</span>
          <span class="badge">Exames Laboratoriais</span>
          <span class="badge">Bioquímica</span>
          <span class="badge">Microbiota Intestinal</span>
          <span class="badge">Congressos Nacionais e Internacionais</span>
          <span class="badge">Membro do IBNF</span>
        </div>
      </div>

      <!-- Mid-page CTA -->
      <div class="mid-cta reveal fade-up">
        <p>Quer saber como funciona uma consulta?</p>
        <Button href={siteInfo.whatsappUrl} variant="primary" size="md" isExternal>
          Fale comigo no WhatsApp
        </Button>
      </div>
    </div>
  </section>

  <!-- ========== WAVE: dark → cream ========== -->
  <WaveDivider topColor="var(--color-blue-800)" bottomColor="var(--color-cream)" variant={3} flip />

  <!-- ========== MARQUEE ========== -->
  <div class="marquee-section">
    <MarqueeText text="diferenciais técnicos" />
  </div>

  <!-- ========== DIFFERENTIALS (alternating rows) ========== -->
  <section class="differentials" aria-labelledby="differentials-heading">
    <div class="container">
      <SectionHeading overline="DIFERENCIAIS TÉCNICOS" align="center">
        Ferramentas e <em>tecnologia</em>
      </SectionHeading>

      <!-- Row 1: image left, text right -->
      <div class="diff-row reveal fade-up">
        <div class="diff-row-image">
          <img
            src="/images/about/nutricionista-jackeline.png"
            alt="Avaliação física com certificação ISAK"
            width="520"
            height="400"
            loading="lazy"
          />
        </div>
        <div class="diff-row-text">
          <span class="diff-badge">Certificação Internacional</span>
          <h3>Certificação ISAK</h3>
          <p>
            Avaliação física certificada internacionalmente pelo ISAK, modelo australiano de
            padronização de medidas corporais. Precisão e confiabilidade na avaliação da composição
            corporal para acompanhar sua evolução com dados reais.
          </p>
        </div>
      </div>

      <!-- Row 2: text left, image right -->
      <div class="diff-row diff-row--reversed reveal fade-up">
        <div class="diff-row-image">
          <img
            src="/images/about/experiencia2.png"
            alt="Ultrassom Bodymetrix para avaliação corporal"
            width="520"
            height="400"
            loading="lazy"
          />
        </div>
        <div class="diff-row-text">
          <h3>Ultrassom Bodymetrix</h3>
          <p>
            Aparelho de ultrassom que mostra em imagem o tecido de gordura e massa magra, fornecendo
            dados importantes para saúde e performance. Tecnologia de ponta para um acompanhamento
            mais preciso e visual da sua evolução.
          </p>
        </div>
      </div>

      <!-- Row 3: image left, text right -->
      <div class="diff-row reveal fade-up">
        <div class="diff-row-image">
          <img
            src="/images/about/nutricai-personalizada.png"
            alt="Aplicativo do paciente com plano alimentar personalizado"
            width="520"
            height="400"
            loading="lazy"
          />
        </div>
        <div class="diff-row-text">
          <h3>App do Paciente</h3>
          <p>
            Acesso ao aplicativo com plano alimentar, avaliação física, diário alimentar, receitas
            e novidades, além de contato direto via WhatsApp.
          </p>
          <div class="diff-tags">
            <span class="diff-tag">Plano alimentar</span>
            <span class="diff-tag">Avaliação física</span>
            <span class="diff-tag">Diário alimentar</span>
            <span class="diff-tag">Receitas</span>
            <span class="diff-tag">Contato direto</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== VALUES (icon cards) ========== -->
  <section class="values" aria-labelledby="values-heading">
    <div class="container">
      <SectionHeading overline="FILOSOFIA" align="center">
        Minha <em>abordagem</em>
      </SectionHeading>

      <div class="values-grid stagger">
        <div class="value-card reveal fade-up hover-lift">
          <div class="value-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-500)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          </div>
          <h3>Cuidado Individual</h3>
          <p>
            Minha proposta vai além de um plano alimentar. É um processo de cuidado construído de forma
            individual, respeitando suas características bioquímicas, comportamentais e emocionais.
          </p>
        </div>
        <div class="value-card reveal fade-up hover-lift">
          <div class="value-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-500)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c4-4 8-7.5 8-12a8 8 0 10-16 0c0 4.5 4 8 8 12z"/><path d="M12 10V6"/><path d="M10 14c0-1 .5-2 2-2s2 1 2 2"/></svg>
          </div>
          <h3>Nutrição com Propósito</h3>
          <p>
            O planejamento alimentar é pensado para nutrir o corpo de forma adequada, favorecendo a
            melhora do metabolismo e da qualidade de vida. A estética surge como consequência natural.
          </p>
        </div>
        <div class="value-card reveal fade-up hover-lift">
          <div class="value-icon" aria-hidden="true">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-500)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.66 0 3-4.03 3-9s-1.34-9-3-9m0 18c-1.66 0-3-4.03-3-9s1.34-9 3-9m-9 9a9 9 0 019-9"/></svg>
          </div>
          <h3>Resultado Duradouro</h3>
          <p>
            Acredito em transformação de dentro para fora. Quando o corpo funciona melhor, o resultado
            físico acontece de forma natural e duradoura — sem extremismos.
          </p>
        </div>
      </div>

      <!-- Inline CTA -->
      <div class="inline-cta reveal fade-up">
        <p>Pronta para começar sua jornada?</p>
        <Button href={siteInfo.whatsappUrl} variant="outline" size="md" isExternal>
          Agende sua Consulta
        </Button>
      </div>
    </div>
  </section>

  <!-- ========== WAVE + FINAL CTA ========== -->
  <WaveDivider topColor="var(--color-cream)" bottomColor="var(--color-blue-800)" variant={1} />

  <FinalCTA id="sobre-cta-heading" />

</BaseLayout>

<style>
  /* ========== HERO (fullwidth bg image) ========== */
  .sobre-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 0;
    padding-bottom: 0;
  }

  .sobre-hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 130vh;
    z-index: 0;
    overflow: hidden;
    will-change: transform;
  }

  .sobre-hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .sobre-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(30, 52, 80, 0.5) 0%,
      rgba(30, 52, 80, 0.4) 40%,
      rgba(30, 52, 80, 0.35) 70%,
      rgba(30, 52, 80, 0.5) 100%
    );
  }

  .sobre-hero-content {
    position: relative;
    z-index: 2;
    padding-top: calc(80px + var(--space-16));
    padding-bottom: calc(var(--space-20) + 60px);
    max-width: 700px;
  }

  .sobre-hero-content .overline { color: var(--color-orange-400); }
  .sobre-hero-content h1 { color: var(--color-white); margin-top: var(--space-3); text-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .sobre-hero-content h1 em { color: var(--color-orange-400); font-style: italic; }
  .sobre-hero-content p { color: rgba(255,255,255,0.9); margin-top: var(--space-4); text-shadow: 0 1px 8px rgba(0,0,0,0.1); }

  .sobre-hero-wave {
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    z-index: 3;
    line-height: 0;
  }

  .sobre-hero-wave svg {
    width: 100%;
    height: clamp(70px, 9vw, 130px);
    display: block;
  }

  /* ========== BIO (image left, text right) ========== */
  .bio { background-color: var(--color-cream); }

  .bio-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  .bio-image-wrapper {
    position: relative;
  }

  .bio-image-wrapper::before {
    content: '';
    position: absolute;
    top: var(--space-4);
    left: calc(-1 * var(--space-4));
    width: 100%;
    height: 100%;
    background: var(--color-orange-100);
    border-radius: var(--radius-2xl);
    z-index: 0;
  }

  .bio-image-wrapper img {
    position: relative;
    z-index: 1;
    border-radius: var(--radius-2xl);
    width: 100%;
    max-width: 480px;
    object-fit: cover;
  }

  .bio-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .bio-text h2 em {
    font-style: italic;
    color: var(--color-orange-500);
  }

  .bio-text blockquote {
    font-family: var(--font-primary);
    font-style: italic;
    font-size: var(--text-h4);
    color: var(--color-orange-500);
    border-left: 3px solid var(--color-orange-500);
    padding-left: var(--space-6);
    margin-top: var(--space-4);
  }

  /* ========== STATS BANNER ========== */
  .stats-banner {
    background-color: var(--color-orange-100);
    padding-block: var(--space-12);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
    text-align: center;
  }

  .stat-item {
    padding-top: var(--space-4);
    border-top: 2px solid var(--color-orange-500);
  }

  .stat-number {
    display: block;
    font-family: var(--font-primary);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: var(--weight-bold);
    color: var(--color-blue-800);
    line-height: 1.1;
  }

  .stat-label {
    display: block;
    font-size: var(--text-small);
    color: var(--color-charcoal-600);
    margin-top: var(--space-2);
    max-width: 18ch;
    margin-inline: auto;
  }

  /* ========== EXPERIENCE (timeline + image) ========== */
  .experience { background-color: var(--color-cream); }

  .experience-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  .experience-timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    position: relative;
    padding-left: var(--space-8);
  }

  .experience-timeline::before {
    content: '';
    position: absolute;
    left: 10px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-charcoal-200);
  }

  .timeline-item { position: relative; }

  .timeline-marker {
    position: absolute;
    left: calc(-1 * var(--space-8) + 4px);
    top: 6px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--color-orange-500);
    border: 3px solid var(--color-cream);
  }

  .timeline-content h3 {
    font-size: var(--text-h4);
    margin-bottom: var(--space-2);
  }

  .timeline-content p {
    color: var(--color-charcoal-600);
  }

  .experience-image {
    display: none;
  }

  .experience-image img {
    border-radius: var(--radius-2xl);
    width: 100%;
    object-fit: cover;
  }

  /* ========== CREDENTIALS ========== */
  .credentials {
    background-color: var(--color-blue-800);
    background-image:
      radial-gradient(ellipse at 20% 80%, rgba(74, 106, 143, 0.25) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 20%, rgba(200, 134, 10, 0.04) 0%, transparent 40%);
  }

  .credentials-grid {
    display: grid;
