---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
import WaveDivider from '../components/ui/WaveDivider.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import ServiceCard from '../components/ui/ServiceCard.astro';
import MarqueeText from '../components/ui/MarqueeText.astro';
import TestimonialCard from '../components/ui/TestimonialCard.astro';
import FinalCTA from '../components/ui/FinalCTA.astro';
import { siteInfo } from '../data/navigation';
import { services, testimonials } from '../data/services';
import { atendimentoFaqItems } from '../data/faq';
import { getBreadcrumbSchema, getLocalBusinessSchema, getServiceSchema } from '../data/seo';
import FAQAccordion from '../components/ui/FAQAccordion.astro';

const atendimentoFaqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: atendimentoFaqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer.replace(/<[^>]*>/g, ''),
    },
  })),
};

const structuredData = [
  getLocalBusinessSchema(),
  getServiceSchema(),
  atendimentoFaqSchema,
  getBreadcrumbSchema([
    { name: 'Home', url: 'https://nutricionistajackeline.com.br/' },
    { name: 'Atendimento e Consultas', url: 'https://nutricionistajackeline.com.br/atendimento-e-consultas/' },
  ]),
];
---

<BaseLayout
  title="Consulta com Nutricionista em São Paulo | Dra Jackeline Queiroz"
  description="Conheça os formatos de acompanhamento nutricional: consulta avulsa, trimestral e 6 meses. Nutrição personalizada para emagrecimento, composição corporal e performance. Agende pelo WhatsApp."
  structuredData={structuredData}
>

  <!-- ========== HERO ========== -->
  <section class="atend-hero" aria-labelledby="atend-heading">
    <div class="atend-hero-bg" id="hero-parallax-bg" aria-hidden="true">
      <img src="/images/about/experiencia.png" alt="" class="atend-hero-bg-img" width="1440" height="900" fetchpriority="high" />
      <div class="atend-hero-overlay"></div>
    </div>
    <div class="container atend-hero-content">
      <div class="reveal fade-up">
        <span class="overline">Atendimento</span>
        <h1 id="atend-heading">Não é uma consulta. É um <em>acompanhamento estratégico.</em></h1>
        <p>
          A consultoria nutricional é um formato de atendimento contínuo, criado para pessoas que não querem
          apenas receber um plano alimentar, mas sim conseguir aplicar a alimentação na vida real e sustentar resultados.
        </p>
      </div>
    </div>
    <div class="atend-hero-wave" aria-hidden="true">
      <svg viewBox="0 0 1440 150" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,80 C240,140 480,20 720,80 C960,140 1200,40 1440,80 L1440,150 L0,150 Z" fill="var(--color-cream)" />
      </svg>
    </div>
  </section>

  <!-- ========== FORMAT (text + checklist + image) ========== -->
  <section class="format" aria-labelledby="format-heading">
    <div class="container format-grid">
      <div class="format-text reveal fade-up">
        <span class="overline">Formato de Consultoria</span>
        <h2 id="format-heading">Acompanhamento individualizado e adaptado à <em>sua rotina</em></h2>
        <p>
          O atendimento nutricional é individualizado e focado em resultados reais. Mais do que entregar um
          cardápio, o objetivo é entender a sua rotina, ajustar estratégias e construir hábitos que funcionem no dia a dia.
        </p>
        <ul class="format-checklist">
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Composição corporal e saúde metabólica
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Nutrição clínica, esportiva e funcional
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Saúde da mulher: lipedema, endometriose, alterações intestinais
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Hábitos alimentares que funcionam no dia a dia
          </li>
        </ul>
        <Button href={siteInfo.whatsappUrl} variant="primary" isExternal>
          Entrar em contato
        </Button>
      </div>
      <div class="format-image reveal scale-in">
        <img src="/images/about/nutricionista-jackeline5.png" alt="Dra Jackeline Queiroz durante atendimento" width="480" height="580" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- ========== MARQUEE ========== -->
  <div class="marquee-section">
    <MarqueeText text="nossos serviços" />
  </div>

  <!-- ========== SERVICES (sticky cards) ========== -->
  <section class="atend-services" aria-labelledby="atend-services-heading">
    <div class="container">
      <SectionHeading overline="FORMATOS DE ACOMPANHAMENTO">
        <Fragment set:html={'Conheça os <em>formatos</em> de atendimento'} />
      </SectionHeading>

      <div class="services-sticky-stack">
        {services.map((svc, i) => (
          <div class="sticky-card-wrapper" style={`--card-index: ${i};`}>
            <ServiceCard
              number={svc.number}
              title={svc.title}
              description={svc.description}
              href={svc.href}
              linkText={svc.linkText}
              variant={i % 2 === 0 ? 'dark' : 'light'}
              image={svc.image}
              imageAlt={svc.imageAlt}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== WAVE: cream → dark ========== -->
  <WaveDivider topColor="var(--color-cream)" bottomColor="var(--color-blue-800)" variant={1} />

  <!-- ========== WHO IS IT FOR ========== -->
  <section class="who text-on-dark" aria-labelledby="who-heading">
    <div class="container container--narrow">
      <div class="reveal fade-up" style="text-align: center;">
        <span class="overline">Para quem é</span>
        <h2 id="who-heading">Para quem já tentou sozinho e quer <em>fazer diferente</em></h2>
      </div>

      <div class="who-grid stagger">
        <div class="who-card reveal fade-up">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>Já tentou emagrecer ou melhorar a alimentação várias vezes</span>
        </div>
        <div class="who-card reveal fade-up">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>Sabe o que precisa fazer, mas tem dificuldade em manter constância</span>
        </div>
        <div class="who-card reveal fade-up">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>Treina, mas sente que a alimentação não acompanha o esforço</span>
        </div>
        <div class="who-card reveal fade-up">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-400)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>Busca resultado físico sem dietas restritivas ou soluções temporárias</span>
        </div>
      </div>

      <p class="who-reinforcement reveal fade-up">
        Você não recebe apenas um plano alimentar. Você recebe direcionamento, suporte e acompanhamento
        ao longo do caminho, para construir autonomia e segurança nas escolhas alimentares.
      </p>
    </div>
  </section>

  <!-- ========== WAVE: dark → cream ========== -->
  <WaveDivider topColor="var(--color-blue-800)" bottomColor="var(--color-cream)" variant={3} flip />

  <!-- ========== STEPS ========== -->
  <section class="steps" aria-labelledby="steps-heading">
    <div class="container">
      <SectionHeading overline="COMO FUNCIONA" align="center">
        O passo a passo da <em>sua consulta</em>
      </SectionHeading>
      <div class="steps-grid stagger">
        <div class="step-card reveal fade-up">
          <div class="step-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-500)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="12" y2="18"/></svg>
          </div>
          <span class="step-number">01</span>
          <h3>Anamnese completa</h3>
          <p>Rotina, hábitos, antecedentes, alimentação, exercícios e preferências — entendemos tudo sobre você.</p>
        </div>
        <div class="step-card reveal fade-up">
          <div class="step-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-500)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/><line x1="12" y1="11" x2="12" y2="17"/><line x1="9" y1="14" x2="15" y2="14"/></svg>
          </div>
          <span class="step-number">02</span>
          <h3>Avaliação física</h3>
          <p>Medidas com certificação ISAK internacional e ultrassom Bodymetrix para dados precisos de composição corporal.</p>
        </div>
        <div class="step-card reveal fade-up">
          <div class="step-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-500)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
          </div>
          <span class="step-number">03</span>
          <h3>Estratégia nutricional</h3>
          <p>Plano alimentar personalizado, construído junto com você, para ser viável e executável no dia a dia.</p>
        </div>
        <div class="step-card reveal fade-up">
          <div class="step-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-orange-500)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <span class="step-number">04</span>
          <h3>Acompanhamento</h3>
          <p>Plano alimentar e avaliação enviados por e-mail, acesso ao app do paciente e contato direto via WhatsApp.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WAVE: cream → dark (testimonial) ========== -->
  <WaveDivider topColor="var(--color-cream)" bottomColor="var(--color-blue-800)" variant={2} />

  <!-- ========== TESTIMONIAL ========== -->
  <section class="testimonial-section" aria-labelledby="testimonial-heading">
    <div class="container">
      <h2 id="testimonial-heading" class="sr-only">Depoimento de paciente</h2>
      <div class="reveal fade-up">
        <TestimonialCard
          quote={testimonials[0].quote}
          author={testimonials[0].author}
          stars={5}
        />
      </div>
    </div>
  </section>

  <!-- ========== WAVE: dark → cream (why-choose) ========== -->
  <WaveDivider topColor="var(--color-blue-800)" bottomColor="var(--color-cream)" variant={3} flip />

  <!-- ========== POR QUE ESCOLHER ========== -->
  <section class="why-choose" aria-labelledby="why-choose-heading">
    <div class="container container--narrow">
      <SectionHeading overline="DIFERENCIAIS" align="center">
        Por que escolher a <em>Dra Jackeline Queiroz?</em>
      </SectionHeading>
      <div class="why-grid stagger">
        <div class="why-item reveal fade-up">
          <strong>+15 anos de experiência clínica</strong>
          <p>Mais de 2000 pacientes acompanhados em consultório em São Paulo.</p>
        </div>
        <div class="why-item reveal fade-up">
          <strong>3 pós-graduações</strong>
          <p>Nutrição Clínica Funcional, Nutrição Esportiva Funcional e Nutrição Clínica e Terapia Nutricional.</p>
        </div>
        <div class="why-item reveal fade-up">
          <strong>Certificação ISAK internacional</strong>
          <p>Avaliação antropométrica com padrão internacional de precisão.</p>
        </div>
        <div class="why-item reveal fade-up">
          <strong>Ultrassom Bodymetrix</strong>
          <p>Tecnologia de ultrassom para medição precisa de gordura corporal e massa magra.</p>
        </div>
        <div class="why-item reveal fade-up">
          <strong>3 consultórios em São Paulo</strong>
          <p>Bela Vista, Pinheiros e Perdizes — flexibilidade de localização para sua rotina.</p>
        </div>
        <div class="why-item reveal fade-up">
          <strong>App exclusivo do paciente</strong>
          <p>Plano alimentar, avaliação, diário alimentar e receitas na palma da mão.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== WAVE: cream → orange-100 (FAQ) ========== -->
  <WaveDivider topColor="var(--color-cream)" bottomColor="var(--color-orange-100)" variant={3} />

  <!-- ========== FAQ ATENDIMENTO ========== -->
  <section class="atend-faq" aria-labelledby="atend-faq-heading">
    <div class="container container--narrow">
      <SectionHeading overline="DÚVIDAS FREQUENTES" align="center">
        Perguntas sobre o <em>atendimento</em>
      </SectionHeading>
      <FAQAccordion items={atendimentoFaqItems} />
    </div>
  </section>

  <!-- ========== WAVE: orange-100 → dark (final CTA) ========== -->
  <WaveDivider topColor="var(--color-orange-100)" bottomColor="var(--color-blue-800)" variant={1} />

  <!-- ========== FINAL CTA ========== -->
  <FinalCTA
    overline="Pronta para começar?"
    heading="O primeiro passo é sempre o"
    headingEmphasis="mais importante."
    description="Entre em contato e agende sua consulta. Você não precisa resolver tudo sozinha."
    id="atend-cta-heading"
  />

</BaseLayout>

<style>
  /* ========== HERO ========== */
  .atend-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 0;
    padding-bottom: 0;
  }
  .atend-hero-bg { position: absolute; top: 0; left: 0; right: 0; height: 130vh; z-index: 0; overflow: hidden; will-change: transform; }
  .atend-hero-bg-img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
  .atend-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(30,52,80,0.5) 0%, rgba(30,52,80,0.4) 40%, rgba(30,52,80,0.35) 70%, rgba(30,52,80,0.5) 100%);
  }
  .atend-hero-content {
    position: relative; z-index: 2;
    padding-top: calc(80px + var(--space-16));
    padding-bottom: calc(var(--space-20) + 60px);
    max-width: 700px;
    text-align: center;
    margin-inline: auto;
  }
  .atend-hero-content .overline { color: var(--color-orange-400); }
  .atend-hero-content h1 { color: var(--color-white); font-size: var(--text-h1); margin-top: var(--space-3); text-shadow: 0 2px 20px rgba(0,0,0,0.15); }
  .atend-hero-content h1 em { color: var(--color-orange-400); font-style: italic; }
  .atend-hero-content p { color: rgba(255,255,255,0.9); margin-top: var(--space-4); margin-inline: auto; max-width: 55ch; text-shadow: 0 1px 8px rgba(0,0,0,0.1); }
  .atend-hero-wave { position: absolute; bottom: -2px; left: 0; right: 0; z-index: 3; line-height: 0; }
  .atend-hero-wave svg { width: 100%; height: clamp(70px, 9vw, 130px); display: block; }

  /* ========== FORMAT ========== */
  .format { background-color: var(--color-cream); }
  .format-grid { display: grid; grid-template-columns: 1fr; gap: var(--space-10); align-items: center; }
  .format-text { display: flex; flex-direction: column; gap: var(--space-4); }
  .format-text h2 em { color: var(--color-orange-500); font-style: italic; }
  .format-image img { border-radius: var(--radius-2xl); width: 100%; max-width: 480px; }

  .format-checklist {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }

  .format-checklist li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    color: var(--color-charcoal-700);
    font-size: var(--text-body);
    line-height: 1.5;
  }

  .format-checklist li svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* ========== MARQUEE ========== */
  .marquee-section {
    background-color: var(--color-orange-100);
    color: var(--color-orange-600);
    overflow: hidden;
  }

  /* ========== SERVICES ========== */
  .atend-services { background-color: var(--color-cream); }

  .services-sticky-stack {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sticky-card-wrapper {
    position: sticky;
    top: calc(80px + var(--card-index, 0) * 8px);
    z-index: calc(var(--card-index, 0) + 1);
    padding-bottom: var(--space-6);
  }

  .sticky-card-wrapper :global(.service-card) {
    box-shadow: 0 -4px 30px rgba(0, 0, 0, 0.08), 0 10px 40px rgba(0, 0, 0, 0.12);
  }

  /* ========== WHO IS IT FOR ========== */
  .who {
    background-color: var(--color-blue-800);
    background-image:
      radial-gradient(ellipse at 20% 50%, rgba(74, 106, 143, 0.25) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 50%, rgba(200, 134, 10, 0.04) 0%, transparent 40%);
  }
  .who h2 { color: var(--color-white); }
  .who h2 em { color: var(--color-orange-400); font-style: italic; }

  .who-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .who-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-lg);
    transition: background var(--duration-normal) ease, border-color var(--duration-normal) ease;
  }

  .who-card:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.15);
  }

  .who-card svg {
    flex-shrink: 0;
  }

  .who-card span {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--text-body);
  }

  .who-reinforcement {
    color: rgba(255, 255, 255, 0.8);
    margin-top: var(--space-8);
    max-width: 50ch;
    margin-inline: auto;
    text-align: center;
  }

  /* ========== STEPS ========== */
  .steps { background-color: var(--color-cream); }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .step-card {
    background: var(--color-white);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    text-align: center;
    border: 1px solid rgba(46, 74, 110, 0.06);
    position: relative;
    overflow: hidden;
  }

  .step-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-orange-400), var(--color-orange-500));
  }

  .step-icon {
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-orange-100);
    border-radius: var(--radius-md);
    margin: 0 auto var(--space-3);
  }

  .step-number {
    font-family: var(--font-primary);
    font-size: var(--text-h1);
    font-weight: var(--weight-bold);
    color: var(--color-orange-100);
    display: block;
    margin-bottom: var(--space-3);
  }

  .step-card h3 { margin-bottom: var(--space-2); color: var(--color-blue-700); }
  .step-card p { color: var(--color-charcoal-600); max-width: none; }

  /* ========== TESTIMONIAL ========== */
  .testimonial-section {
    background-color: var(--color-blue-800);
    padding-block: var(--space-16);
  }

  /* ========== WHY CHOOSE ========== */
  .why-choose { background-color: var(--color-cream); }
  .why-choose h2 em { color: var(--color-orange-500); font-style: italic; }

  .why-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .why-item {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-6);
    border-left: none;
    box-shadow: var(--shadow-sm);
  }

  .why-item strong {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-body);
    color: var(--color-blue-700);
    margin-bottom: var(--space-1);
  }

  .why-item p {
    font-size: var(--text-small);
    color: var(--color-charcoal-600);
    max-width: none;
  }

  /* ========== ATEND FAQ ========== */
