---
interface Props {
  quote: string;
  author: string;
  image?: string;
  stars?: number;
}

const { quote, author, image, stars = 5 } = Astro.props;
---

<div class="testimonial-card">
  {image && (
    <div class="testimonial-avatar">
      <img src={image} alt={`Foto de ${author}`} width="80" height="80" loading="lazy" />
    </div>
  )}
  <div class="testimonial-stars" aria-label={`${stars} estrelas`}>
    {Array(stars).fill(null).map(() => (
      <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-orange-400)" aria-hidden="true">
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
      </svg>
    ))}
  </div>
  <blockquote class="testimonial-quote">
    &ldquo;{quote}&rdquo;
  </blockquote>
  <cite class="testimonial-author">— {author}</cite>
</div>

<style>
  .testimonial-card {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    max-width: 700px;
    margin-inline: auto;
  }

  .testimonial-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-orange-400);
  }

  .testimonial-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-stars {
    display: flex;
    gap: var(--space-1);
  }

  .testimonial-quote {
    font-family: var(--font-primary);
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: var(--weight-medium);
    font-style: italic;
    line-height: var(--leading-normal);
    color: var(--color-white);
  }

  .testimonial-author {
    font-family: var(--font-secondary);
    font-size: var(--text-small);
    font-style: italic;
    color: var(--color-orange-400);
  }
</style>
