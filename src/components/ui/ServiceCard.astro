---
interface Props {
  number: string;
  title: string;
  description: string;
  image?: string;
  imageAlt?: string;
  href: string;
  linkText?: string;
  variant?: 'dark' | 'light';
  icon?: string;
}

const {
  number,
  title,
  description,
  image,
  imageAlt,
  href,
  linkText = 'Saiba mais',
  variant = 'dark',
  icon,
} = Astro.props;

const hasImage = image && !image.includes('undefined');
---

<div class:list={['service-card', `card-${variant}`, 'hover-lift']}>
  <div class="card-content">
    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>
    <a href={href} class="card-link" target={href.startsWith('http') ? '_blank' : undefined} rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}>
      <span>→</span> {linkText.toUpperCase()}
    </a>
  </div>
  <div class="card-visual">
    <span class="card-number">{number}</span>
    {hasImage ? (
      <div class="card-image hover-scale">
        <img src={image} alt={imageAlt || title} loading="lazy" width="400" height="300" />
      </div>
    ) : (
      <div class="card-decorative">
        <Fragment set:html={icon || `<svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/></svg>`} />
      </div>
    )}
  </div>
</div>

<style>
  .service-card {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    border-radius: var(--radius-2xl);
    padding: var(--space-8);
    transition:
      transform var(--duration-normal) var(--ease-out-expo),
      box-shadow var(--duration-normal) var(--ease-out-expo);
    position: relative;
    overflow: hidden;
  }

  .card-dark {
    background-color: var(--color-blue-700);
    color: var(--color-white);
  }

  .card-light {
    background-color: var(--color-orange-100);
    color: var(--color-charcoal-900);
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    z-index: 1;
  }

  .card-visual {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-4);
  }

  .card-number {
    font-family: var(--font-primary);
    font-size: var(--text-small);
    font-weight: var(--weight-medium);
    opacity: 0.5;
    letter-spacing: 0.15em;
  }

  .card-title {
    font-size: var(--text-h2);
    font-weight: var(--weight-bold);
    color: inherit;
  }

  .card-description {
    font-size: var(--text-body);
    line-height: var(--leading-relaxed);
    max-width: none;
  }

  .card-dark .card-description {
    color: rgba(255, 255, 255, 0.8);
  }

  .card-light .card-description {
    color: var(--color-charcoal-600);
  }

  .card-link {
    font-family: var(--font-secondary);
    font-size: var(--text-small);
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    text-decoration: none;
    color: inherit;
    margin-top: var(--space-4);
    display: inline-flex;
    gap: var(--space-2);
    transition: gap var(--duration-fast) ease;
  }

  .card-link:hover {
    gap: var(--space-3);
    text-decoration: underline;
  }

  .card-image {
    border-radius: var(--radius-lg);
    overflow: hidden;
    width: 100%;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4/3;
  }

  .card-decorative {
    width: 100%;
    aspect-ratio: 16/10;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .card-decorative::before {
    content: '';
    position: absolute;
    inset: 0;
    opacity: 0.06;
    background-image:
      radial-gradient(circle at 20% 30%, currentColor 1px, transparent 1px),
      radial-gradient(circle at 80% 70%, currentColor 1px, transparent 1px),
      radial-gradient(circle at 50% 50%, currentColor 1.5px, transparent 1.5px);
    background-size: 40px 40px, 60px 60px, 80px 80px;
  }

  .card-decorative::after {
    content: '';
    position: absolute;
    width: 200%;
    height: 200%;
    top: -50%;
    left: -50%;
    background: radial-gradient(ellipse at center, transparent 30%, currentColor 70%);
    opacity: 0.03;
  }

  .card-dark .card-decorative {
    background: linear-gradient(135deg, rgba(219,164,74,0.08) 0%, rgba(255,255,255,0.03) 40%, rgba(74,106,143,0.1) 100%);
    color: rgba(255,255,255,0.25);
  }

  .card-light .card-decorative {
    background: linear-gradient(135deg, rgba(46,74,110,0.06) 0%, rgba(200,134,10,0.04) 40%, rgba(46,74,110,0.08) 100%);
    color: rgba(46,74,110,0.15);
  }

  .card-decorative :global(svg) {
    width: 96px;
    height: 96px;
    position: relative;
    z-index: 1;
    opacity: 0.7;
    filter: drop-shadow(0 4px 12px rgba(0,0,0,0.08));
  }

  @media (min-width: 768px) {
    .service-card {
      grid-template-columns: 1.2fr 1fr;
      padding: var(--space-10);
      min-height: 380px;
    }

    .card-visual {
      grid-row: 1;
    }
  }
</style>
