---
import { siteInfo } from '../../data/navigation';
---

<div class="whatsapp-widget" id="whatsapp-widget">
  <a href={siteInfo.whatsappUrl} target="_blank" rel="noopener noreferrer" class="whatsapp-btn pulse" aria-label="Conversar pelo WhatsApp" id="whatsapp-toggle">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <div class="whatsapp-chat" id="whatsapp-chat" aria-hidden="true">
    <div class="chat-header">
      <strong>Jackeline Queiroz</strong>
      <span>Nutricionista</span>
    </div>
    <div class="chat-body">
      <div class="chat-bubble">
        Olá! Posso ajudá-lo? Tire suas dúvidas ou agende sua consulta.
      </div>
    </div>
    <a
      href={siteInfo.whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="chat-send"
    >
      Iniciar conversa
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
      </svg>
    </a>
  </div>
</div>

<style>
  .whatsapp-widget {
    position: fixed;
    bottom: var(--space-6);
    right: var(--space-6);
    z-index: var(--z-whatsapp);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-3);
  }

  .whatsapp-btn {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-color: #25d366;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-lg);
    position: relative;
    transition: transform var(--duration-fast) ease;
  }

  .whatsapp-btn:hover {
    transform: scale(1.08);
  }

  .whatsapp-chat {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    width: 300px;
    overflow: hidden;
    opacity: 0;
    transform: translateY(10px) scale(0.95);
    pointer-events: none;
    transition: opacity var(--duration-normal) var(--ease-out-expo),
                transform var(--duration-normal) var(--ease-out-expo);
  }

  .whatsapp-chat[aria-hidden='false'] {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .chat-header {
    background-color: #075e54;
    color: white;
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
  }

  .chat-header strong {
    font-family: var(--font-primary);
    font-size: var(--text-small);
  }

  .chat-header span {
    font-size: var(--text-caption);
    opacity: 0.8;
  }

  .chat-body {
    padding: var(--space-4);
    background-color: #e5ddd5;
  }

  .chat-bubble {
    background: var(--color-white);
    padding: var(--space-3) var(--space-4);
    border-radius: 0 var(--radius-sm) var(--radius-sm) var(--radius-sm);
    font-size: var(--text-small);
    color: var(--color-charcoal-800);
    box-shadow: var(--shadow-sm);
    line-height: 1.5;
  }

  .chat-send {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-4);
    background-color: #25d366;
    color: white;
    font-family: var(--font-primary);
    font-size: var(--text-small);
    font-weight: var(--weight-medium);
    text-decoration: none;
    transition: background-color var(--duration-fast) ease;
  }

  .chat-send:hover {
    background-color: #1da851;
  }
</style>

<script>
  // Delayed entrance
  const widget = document.getElementById('whatsapp-widget');
  if (widget) {
    widget.style.opacity = '0';
    widget.style.transform = 'translateY(20px)';
    widget.style.transition = 'opacity 0.5s ease, transform 0.5s ease';

    const show = () => {
      widget.style.opacity = '1';
      widget.style.transform = 'translateY(0)';
    };

    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => setTimeout(show, 2000));
    } else {
      setTimeout(show, 3000);
    }
  }

  // Toggle chat
  const toggleBtn = document.getElementById('whatsapp-toggle');
  const chat = document.getElementById('whatsapp-chat');

  if (toggleBtn && chat) {
    toggleBtn.addEventListener('click', () => {
      const isOpen = chat.getAttribute('aria-hidden') === 'false';
      chat.setAttribute('aria-hidden', String(!isOpen));
    });

    // Close on outside click
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (!target.closest('.whatsapp-widget') && chat.getAttribute('aria-hidden') === 'false') {
        chat.setAttribute('aria-hidden', 'true');
      }
    });
  }
</script>
